# DEBUG | INFO | WARNING | ERROR | CRITICAL
LOG_LEVEL=INFO

# dev | prod
ENV=prod

# API root path
ROOT_PATH=/api/v1

# Database Configuration
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
POSTGRES_DB=knowledge_gateway_db
POSTGRES_USER=user
POSTGRES_PASSWORD=password

# Qdrant configuration
QDRANT_URL=http://qdrant:6333
QDRANT_API_KEY=change-me

# Used for hashing API keys — generate with: python -c "import secrets; print(secrets.token_hex(32))"
API_KEY_PEPPER=change-me

# Used to encrypt provider API keys at rest. Required when any provider record has an api_key.
# Generate with: python -c "import secrets; print(secrets.token_hex(32))"
PROVIDER_SECRET_KEY=change-me

# Default prefix for generated API keys
API_KEY_DEFAULT_PREFIX=syn_kg

# Comma-separated IPs of trusted reverse proxies (e.g. "172.18.0.1,10.0.0.1")
# Only these IPs are allowed to set X-Forwarded-For. Leave empty if no proxy.
TRUSTED_PROXY_IPS=

# Redis URL for per-user rate limiting
REDIS_URL=redis://redis:6379

# Default requests/minute for newly created users (0 = unlimited)
RATE_LIMIT_DEFAULT_REQUESTS_PER_MINUTE=60

# Default admin bootstrap
BOOTSTRAP_ADMIN_NAME=default_admin
BOOTSTRAP_ADMIN_API_KEY_NAME=admin1
BOOTSTRAP_ADMIN_API_KEY=change-me
# Password for the default admin's interactive (admin panel) login. When set, it is applied to the
# default admin on startup if it has no password yet. Leave empty to disable password login.
BOOTSTRAP_ADMIN_PASSWORD=change-me

# Interactive session auth (admin panel). Sessions live in Redis; the token rides in an httpOnly
# cookie. Set SESSION_COOKIE_SECURE=false for local dev over plain HTTP.
SESSION_COOKIE_NAME=knowledge_gateway_session
SESSION_TTL_SECONDS=28800
SESSION_COOKIE_SECURE=true
# strict | lax | none
SESSION_COOKIE_SAMESITE=strict

# Document upload max size in bytes
DOCUMENT_UPLOAD_MAX_BYTES=10485760

# Document chunking settings
DOCUMENT_CHUNK_MAX_CHARS=2500
DOCUMENT_CHUNK_OVERLAP_CHARS=250
RAG_RETRIEVAL_LIMIT=10
RAG_CONTEXT_MAX_CHARS=12000

# Grafana admin credentials (monitoring profile only)
GRAFANA_ADMIN_USER=admin
GRAFANA_ADMIN_PASSWORD=change-me
